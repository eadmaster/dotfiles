#!/bin/bash

INPUT="$1"
[ -z "$1" ] && while read -r line ; do $0 "$line" ; done && exit $?
[ -f "$1" ] && while read -r line ; do $0 "$line" ; done < "$1"  && exit $?

# remove any spaces from input
INPUT=$(echo "$INPUT" | tr -d ' ')

# Check if the length is a multiple of 4 (2 bytes)
if [ $(( ${#INPUT} % 4 )) -ne 0 ]; then
    echo "Error: Input hex string length must be a multiple of 4 (e.g., 83498376)"
    exit 1
fi

OUTPUT=""

# Loop through the string 4 characters at a time
for (( i=0; i<${#INPUT}; i+=4 )); do
    # Get the 4-char block (e.g., 8349)
    BLOCK="${INPUT:i:4}"
    
    # Split and swap (83 49 -> 49 83)
    HIGH="${BLOCK:0:2}"
    LOW="${BLOCK:2:2}"
    
    OUTPUT="${OUTPUT}${LOW}${HIGH}"
done

echo "$OUTPUT"