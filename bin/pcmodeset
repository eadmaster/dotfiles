#!/bin/sh

# enable autolock
#loginctl lock-session

if [ "$(hostname)" = "BOSS2" ]; then
	#lgtv_serial poweron
	# TODO: check current status, if it is off then
	#sleep 5
	lgtv_serial inputhdmi1
	lgtv_serial energysavingmax
	# TODO: turn on tv speaker if off
	lgtv_serial unmute
	lgtv_serial volume20
	lgtv_serial brightness50
	
	cpuset 80

elif [ "$(hostname)" = "PICCIOTTO3" ]; then

	# set performance governor
	#sudo cpupower frequency-set -g powersave
	
	# disable turbo boost
	echo 1|sudo tee /sys/devices/system/cpu/intel_pstate/no_turbo
	
	# set GPU reduced max freq.
	#gpuset 50
	
	# switch to KDE activity "gaming"  https://blog.hanschen.org/2011/05/20/switch-to-specific-activities-with-keyboard-shortcuts/
	#qdbus org.kde.ActivityManager /ActivityManager/Activities SetCurrentActivity da9a261c-328d-454e-9f97-e4d417b1331a
	
	#resolutionset 1920x1080

	# LG monitor Picture Mode: Reader (preset)
	ddccontrol -r 0x15 -w 1 $MONITOR_DDC_I2C_PATH
	# LG monitor Color Preset: warm
	#ddccontrol -r 0x14 -w 5  $MONITOR_DDC_I2C_PATH
	# LG monitor brightness 0%
	ddccontrol -r 0x10 -w 0 $MONITOR_DDC_I2C_PATH
	# LG monitor hardware volume 50%
	#ddccontrol -r 0x62 -w 50 $MONITOR_DDC_I2C_PATH
	# LG monitor aspect ratio: just scan
	ddccontrol -r 0xF5 -w 0  $MONITOR_DDC_I2C_PATH
	# LG monitor Response Time: normal
	#ddccontrol -r 0xF7 -w 3  $MONITOR_DDC_I2C_PATH
	# LG monitor Smart Energy Saving: high
	ddccontrol -r 0xF6 -w 2  $MONITOR_DDC_I2C_PATH

elif [ "$(hostname)" = "PICCIOTTO4" ]; then

	# set performance governor
	#sudo cpupower frequency-set -g powersave
	sudo cpupower frequency-set -g convervative
	
	# disable turbo boost
	echo 0|sudo tee /sys/devices/system/cpu/cpufreq/boost

	# LG monitor Picture Mode: Reader (preset)
	ddccontrol -r 0x15 -w 1 $MONITOR_DDC_I2C_PATH
	# LG monitor Color Preset: warm
	#ddccontrol -r 0x14 -w 5  $MONITOR_DDC_I2C_PATH
	# LG monitor brightness 0%
	ddccontrol -r 0x10 -w 0 $MONITOR_DDC_I2C_PATH
	# LG monitor hardware volume 30%
	ddccontrol -r 0x62 -w 30 $MONITOR_DDC_I2C_PATH
	# LG monitor aspect ratio: original
	ddccontrol -r 0xF5 -w 2  $MONITOR_DDC_I2C_PATH
	# LG monitor Response Time: normal
	ddccontrol -r 0xF7 -w 3  $MONITOR_DDC_I2C_PATH
	# LG monitor Smart Energy Saving: high
	ddccontrol -r 0xF6 -w 2  $MONITOR_DDC_I2C_PATH
	
	
elif [ ! -z "$ANDROID_ROOT" ]; then  # Android detection

	settings put system screen_brightness 100
	# termux-brightness 100
	
	exit 0
fi


gamma 1.0

volumeset 85

# set a warmer color temperature
redshift -P -O 5000

# resume CPU-hungry processes
pkill -CONT firefox
pkill -CONT chromium-browser
pkill -CONT plugin-container
pkill -CONT "python $PENDRIVE/SharedPrograms/eventsmon.py"

# cpusetgovernor powersave

# TODO: disable gamemode ... https://github.com/FeralInteractive/gamemode


