
# https://github.com/ReFirmLabs/binwalk/wiki/Usage
# Some signatures with a high rate of false positives are, by default, only looked for at the beginning of a file. Try running with the -a flag.   https://github.com/redballoonsecurity/ofrak
echo "$0: binwalk scan..."
#binwalk --verbose --extract --signature --carve "$@"  # old
binwalk --verbose   "$@"  # --search-all
# WANTED: better magic file: --magic=/usr/share/misc/magic.mgc

# https://github.com/onekey-sec/unblob
echo "$0: unblob scan..."
unblob --skip-extraction "$@"

# https://github.com/vstinner/hachoir
echo "$0: hachoir-subfile scan..."
hachoir-subfile "$@"

# https://github.com/armijnhemel/binaryanalysis-ng
bang "$@"

# https://aluigi.altervista.org/mytoolz.htm#signsrch
echo "$0: signsrch scan..."
signsrch -s $HOME/.local/bin/signsrch.sig "$@"

# look for well-known containers
#grep -aobP ".{0,16}(BMG1|NARC|MES|BMS |RTXT).{0,16}" -r
sfk hexfind -text "/BMG1/" "/NARC/" "/MES[byte 00]/" "/BMS /" "/RTXT[byte FE][byte FF]/" $INPUT
